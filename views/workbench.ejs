      <span class="wb-tag">Runs entirely in your browser</span>
      <span class="wb-tag">Composes with the Thesis Tracker</span>
    </div>
  </header>

  <!-- THE APP -->
  <section class="wb-shell" aria-label="Desk Workbench application">
    <div id="wb-app" class="wb-appbox"></div>
